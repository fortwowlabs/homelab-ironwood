# Secrets — the encrypted vault is technically safe to commit, but keeping it
# out entirely is the belt-and-suspenders default. Commit the .example only.
inventory/group_vars/all/vault.yml
.vault_pass

# Raw session transcripts — may contain decrypted variables or command output.
# Both names have been used locally; never commit either tree.
docs/sessions/
docs/transcripts/

# Fetched Caddy internal-CA roots (env-specific; regenerated per install)
*-root-ca.crt

# Python venv (created by `make deps`)
.venv/
__pycache__/
*.py[cod]

# Ansible cruft
*.retry
.ansible/
collections/ansible_collections/

# Claude Code local (machine-specific) settings
.claude/settings.local.json

# Editor / OS
*.swp
.DS_Store
