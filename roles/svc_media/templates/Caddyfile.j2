{{ ansible_managed | comment }}
# Caddyfile — svc-media reverse proxy for *.{{ service_domain }}
#
# RENDERED from roles/svc_media/templates/Caddyfile.j2, iterating the
# media/infra `caddy_services` catalog and the proxy-enabled entries in
# `download_apps`. Add services to those catalogs, not here.
#
# Every service is one hostname vhost on :443, bound to the LAN IP
# ({{ ansible_host }}); dnsmasq answers <name>.{{ service_domain }} -> that IP,
# and the tailnet reaches the same IP via the subnet router (Tailscale
# split-DNS). TLS is Caddy's INTERNAL CA (fort.wow isn't a public domain) —
# install its root once per device (docs/deployment.md).

{
	# Issue every site's cert from Caddy's own CA (no public ACME for a
	# private TLD). auto_https still manages renewal/OCSP internally.
	local_certs
	auto_https disable_redirects
	# No HTTP/3: SELinux labels these ports tcp-only, QUIC would EACCES.
	servers {
		protocols h1 h2
	}
}

{% for name, svc in caddy_services | dictsort %}
# --- {{ name }} ---
https://{{ name }}.{{ service_domain }} {
	bind {{ ansible_host }}
	reverse_proxy {{ svc.scheme | default('http') }}://{{ svc.backend }} {
{% if svc.tls_skip_verify | default(false) %}
		transport http {
			tls_insecure_skip_verify
		}
{% endif %}
	}
}

{% endfor %}
{% for name, app in download_apps | dictsort if app.proxy %}
# --- {{ name }} (download catalog) ---
https://{{ name }}.{{ service_domain }} {
	bind {{ ansible_host }}
	reverse_proxy http://{{ hostvars['svc-download'].ansible_host }}:{{ app.ui_port }}
}

{% endfor %}
