{{ ansible_managed | comment('c') }}
# RomM MariaDB bootstrap — rendered from the vault. MARIADB_PASSWORD must
# match DB_PASSWD in romm.env (both are vault_romm_db_password). NOTE: these
# take effect only on FIRST init of an empty data dir; changing them later
# does NOT change an already-initialised DB's passwords (see docs/media.md).
MARIADB_ROOT_PASSWORD={{ vault_romm_db_root_password }}
MARIADB_DATABASE=romm
MARIADB_USER=romm-user
MARIADB_PASSWORD={{ vault_romm_db_password }}
