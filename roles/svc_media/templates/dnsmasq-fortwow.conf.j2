{{ ansible_managed | comment }}
# {{ service_domain }} resolver — RENDERED from roles/svc_media/templates/
# dnsmasq-fortwow.conf.j2, iterating the SAME caddy_services dict as the
# Caddyfile. This box is the authority for {{ service_domain }} only; pfSense
# forwards the domain here (Domain Override) and Tailscale split-DNS points the
# tailnet here too — see docs/dns-and-names.md.

# Bind only the LAN IP so we never fight systemd-resolved on 127.0.0.53.
listen-address={{ svc_media_ip }}
bind-interfaces

# We answer {{ service_domain }} and nothing else; no upstream forwarding.
no-resolv
domain-needed
bogus-priv

# Physical hosts by name.
host-record=svc-media.{{ service_domain }},{{ svc_media_ip }}
host-record=svc-download.{{ service_domain }},{{ svc_download_ip }}
host-record=truenas.{{ service_domain }},{{ truenas_ip }}
host-record=thurgadin.{{ service_domain }},{{ pve_host_ip }}

# Every service name -> Caddy on svc-media (which reverse-proxies by hostname).
{% for name in caddy_services | dictsort | map('first') %}
address=/{{ name }}.{{ service_domain }}/{{ svc_media_ip }}
{% endfor %}
