{{ ansible_managed | comment }}
[Unit]
Description=Nightly svc-media backup (RomM DB dump + appdata tars) to NFS
RequiresMountsFor=/srv/backups

[Service]
Type=oneshot
User=homelab
Group=homelab
Environment=XDG_RUNTIME_DIR=/run/user/{{ svc_uid }}
EnvironmentFile=/etc/homelab-notify.env
ExecStart=/usr/local/sbin/backup-media.sh
