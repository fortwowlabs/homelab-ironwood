{{ ansible_managed | comment('c') }}
# RomM app secrets — rendered from the vault. DB_PASSWD must match
# MARIADB_PASSWORD in romm-db.env (both come from vault_romm_db_password).
DB_HOST=romm-db
DB_NAME=romm
DB_USER=romm-user
DB_PASSWD={{ vault_romm_db_password }}
ROMM_AUTH_SECRET_KEY={{ vault_romm_auth_secret_key }}
{% if vault_romm_igdb_client_id | default('') | length > 0 %}
IGDB_CLIENT_ID={{ vault_romm_igdb_client_id }}
IGDB_CLIENT_SECRET={{ vault_romm_igdb_client_secret }}
{% endif %}
{% if vault_screenscraper_user | default('') | length > 0 %}
SCREENSCRAPER_USER={{ vault_screenscraper_user }}
SCREENSCRAPER_PASSWORD={{ vault_screenscraper_password }}
{% endif %}
{% if vault_steamgriddb_api_key | default('') | length > 0 %}
STEAMGRIDDB_API_KEY={{ vault_steamgriddb_api_key }}
{% endif %}
{% if vault_mobygames_api_key | default('') | length > 0 %}
MOBYGAMES_API_KEY={{ vault_mobygames_api_key }}
{% endif %}
{% if vault_retroachievements_api_key | default('') | length > 0 %}
RETROACHIEVEMENTS_API_KEY={{ vault_retroachievements_api_key }}
{% endif %}
