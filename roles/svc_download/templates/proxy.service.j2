{{ ansible_managed | comment }}
# homelab-iac catalog-managed
[Unit]
Description={{ item.key }} UI proxy
Requires=vpn-netns.service dl-{{ item.key }}.service
After=vpn-netns.service dl-{{ item.key }}.service

[Service]
ExecStart=/usr/lib/systemd/systemd-socket-proxyd --exit-idle-time=5min 10.77.0.2:{{ item.value.ui_port }}
PrivateTmp=yes
ProtectSystem=strict
ProtectHome=yes
NoNewPrivileges=yes
