{{ ansible_managed | comment }}
# /etc/containers/systemd/beszel-agent.container   (rootful, init ns)
# NOT catalog-managed (no download_apps entry, deliberately not in the VPN
# jail — it needs normal LAN egress to reach the hub, which host-backstop.nft
# only allows once vault_beszel_token/_key are configured).
[Unit]
Description=Beszel monitoring agent

[Container]
Image={{ beszel_agent_image }}
ContainerName=beszel-agent
Environment=HUB_URL=http://{{ hostvars[infra_host].ansible_host }}:8090
Environment=TOKEN={{ vault_beszel_token }}
Environment=KEY={{ vault_beszel_key }}
Volume=/srv/appdata/beszel-agent:/var/lib/beszel-agent:Z

[Service]
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
