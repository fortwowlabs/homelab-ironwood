#!/usr/bin/env bash
# Managed by Ansible. Temporarily opens package/registry egress only when the
# svc-download backstop is already active; a fresh VM has normal bootstrap
# egress and needs no temporary rules.
set -euo pipefail

state=/run/homelab-maintenance-egress.open
backstop=/etc/nftables/host-backstop.nft

case "${1:-}" in
  open)
    if ! nft list table inet host_backstop >/dev/null 2>&1; then
      echo "inactive"
      exit 0
    fi
    [[ ! -e "$state" ]] || { echo "maintenance egress is already open" >&2; exit 1; }
    nft list chain inet host_backstop output | grep -q 'policy drop'
    # Record the open transaction before changing the rules. The caller's
    # always block can then restore safely even if a later insertion fails.
    install -m 0600 /dev/null "$state"
    nft insert rule inet host_backstop output ip daddr {{ lan_dns }} udp dport 53 accept
    nft insert rule inet host_backstop output ip daddr {{ lan_dns }} tcp dport 53 accept
    nft insert rule inet host_backstop output tcp dport '{ 80, 443 }' accept
    echo "opened"
    ;;
  close)
    if [[ ! -e "$state" ]]; then
      echo "inactive"
      exit 0
    fi
    # Primary path: atomically reload the strict backstop (delete+recreate the
    # table), which drops the temporary 80/443/DNS accepts along with any drift.
    if nft -f "$backstop"; then
      nft list chain inet host_backstop output | grep -q 'policy drop'
      rm -f "$state"
      echo "closed"
    else
      # The reload failed (e.g. a corrupt mullvad-endpoints.nft include). Never
      # leave the temporary egress accepts in place: flush the output chain so
      # its own `policy drop` alone governs — fail-closed — and exit non-zero so
      # the failure is visible. The state file is left in place so a re-run or
      # `open` won't stack more rules; repair the backstop and re-converge.
      nft flush chain inet host_backstop output || true
      echo "close: backstop reload FAILED — output chain flushed to fail-closed" >&2
      exit 1
    fi
    ;;
  *)
    echo "usage: $0 open|close" >&2
    exit 64
    ;;
esac
