# proxmox/provision.env — global settings, sourced by fetch-image.sh / create-vm.sh
# Copy to provision.env and edit. chmod 600 (contains nothing secret by default,
# but keep the habit).

# --- Proxmox resources ---
STORAGE=local-nvme                 # VM disk storage (your NVMe pool/dir)
SNIPPET_STORAGE=local              # storage with 'snippets' content enabled
SNIPPET_DIR=/var/lib/vz/snippets   # filesystem path of SNIPPET_STORAGE snippets
BRIDGE=vmbr0                       # must be VLAN-aware for svc-download (tag=40)

# --- Image ---
IMAGE_DIR=/var/lib/vz/template/cache
IMAGE_URL=https://dl.rockylinux.org/pub/rocky/10/images/x86_64/Rocky-10-GenericCloud-Base.latest.x86_64.qcow2
CHECKSUM_URL=https://dl.rockylinux.org/pub/rocky/10/images/x86_64/CHECKSUM

# --- Guest identity / bootstrap ---
ADMIN_USER=brandon
ADMIN_SSH_PUBKEY_FILE=/root/.ssh/id_ed25519.pub   # public key injected for ADMIN_USER
TIMEZONE=America/New_York
SEARCHDOMAIN=home.arpa
DNS_LAN=192.168.1.1                # svc-media resolver
