# proxmox/vms/svc-download.env  (no-VLAN variant: flat LAN)
VMID=131
NAME=svc-download
CORES=4
MEMORY=6144
DISK_SIZE=160G
VLAN_TAG=                      # flat LAN — no tag
IP_CIDR=192.168.1.31/24
GATEWAY=192.168.1.1
NAMESERVER_VAR=DNS_LAN         # host DNS is pfSense; blocked by the egress
                               # backstop except during patch windows — the
                               # jail's DNS (Mullvad, via wg0) is unaffected
STARTUP="order=3,up=30"
EXTRA_PACKAGES="wireguard-tools"
