# proxmox/vms/svc-media.env
VMID=130
NAME=svc-media
CORES=4
MEMORY=10240
DISK_SIZE=100G
VLAN_TAG=                      # empty = untagged LAN
IP_CIDR=192.168.1.30/24
GATEWAY=192.168.1.1
NAMESERVER_VAR=DNS_LAN         # which resolver var from provision.env
STARTUP="order=2,up=90"        # TrueNAS VM must be order=1 (set manually);
                               # 90s gives ZFS import time before NFS mounts
EXTRA_PACKAGES="tailscale"     # installed only if repo present; see user-data
