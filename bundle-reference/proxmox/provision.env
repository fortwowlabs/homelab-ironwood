# proxmox/provision.env — PRE-FILLED for thurgadin (audit 2026-05-31).
# Sourced by fetch-image.sh / create-vm.sh. chmod 600 by habit.

# --- Proxmox resources (verified against /etc/pve/storage.cfg) ---
STORAGE=nvme0pool                  # zfspool, content images,rootdir — 1.2T free
SNIPPET_STORAGE=local              # dir /var/lib/vz; Phase 2 adds 'snippets' content
SNIPPET_DIR=/var/lib/vz/snippets
BRIDGE=vmbr0                       # flat LAN; VLAN-awareness not required in this variant

# --- Image ---
IMAGE_DIR=/var/lib/vz/template/cache
IMAGE_URL=https://dl.rockylinux.org/pub/rocky/10/images/x86_64/Rocky-10-GenericCloud-Base.latest.x86_64.qcow2
CHECKSUM_URL=https://dl.rockylinux.org/pub/rocky/10/images/x86_64/CHECKSUM

# --- Guest identity / bootstrap ---
ADMIN_USER=straderb
ADMIN_SSH_PUBKEY_FILE=/root/.ssh/id_ed25519.pub   # put your MBP .pub here (Phase 0.3)
TIMEZONE=America/New_York
SEARCHDOMAIN=fort.wow              # matches thurgadin's /etc/hosts + resolv.conf
DNS_LAN=192.168.1.1                # LAN resolver (router)
