# /etc/systemd/system/radarr-proxy.service  (activated by radarr-proxy.socket)
[Unit]
Description=Radarr UI proxy (VLAN -> 10.77.0.2:7878)
Requires=vpn-netns.service dl-radarr.service
After=vpn-netns.service dl-radarr.service

[Service]
ExecStart=/usr/lib/systemd/systemd-socket-proxyd --exit-idle-time=5min 10.77.0.2:7878
PrivateTmp=yes
ProtectSystem=strict
ProtectHome=yes
NoNewPrivileges=yes
