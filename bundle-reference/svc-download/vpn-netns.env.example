# /etc/vpn-netns.env   (chmod 600)
# Tunnel-internal address assigned by the provider.
WG_ADDR=10.13.128.7/32

# ---------------------------------------------------------------------------
# Also create /etc/netns/vpn/resolv.conf (ip-netns(8) bind-mounts it over
# /etc/resolv.conf for `ip netns exec vpn ...` processes):
#
#   mkdir -p /etc/netns/vpn
#   echo 'nameserver 10.64.0.1' > /etc/netns/vpn/resolv.conf
#
# That resolver is only reachable through wg0, so DNS is structurally
# incapable of leaking: tunnel down => resolution fails.
# NOTE: Podman manages resolv.conf for containers independently of this file;
# the Quadlets pin DNS= for that reason.
# ---------------------------------------------------------------------------
