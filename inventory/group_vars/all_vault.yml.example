---
# ============================================================================
# SECRETS. Copy to all/vault.yml (NOT group_vars/all_vault.yml — that name
# maps to a nonexistent group and is silently ignored) and encrypt:
#     cp inventory/group_vars/all_vault.yml.example inventory/group_vars/all/vault.yml
#     $EDITOR inventory/group_vars/all/vault.yml
#     ansible-vault encrypt inventory/group_vars/all/vault.yml
# Edit later with:  make vault-edit
# all/vault.yml is .gitignored; only the .example (this file) is committed.
# ============================================================================

# --- Proxmox API token (Phase 0 on thurgadin) — SCOPED (v5) ---------------
# v4 granted PVEVMAdmin at / with privilege separation disabled. v5 scopes
# the token to a pool holding only these two VMs + the two storages it
# actually touches, and keeps privsep ON (ACLs go on the token itself).
# Run ON thurgadin, once:
#
#   pveum pool add homelab-svc --comment "svc-download + svc-media"
#   pveum user add automation@pve
#   pveum user token add automation@pve ansible          # privsep stays 1
#   # VM lifecycle inside the pool only:
#   pveum aclmod /pool/homelab-svc -user automation@pve -role PVEVMAdmin
#   pveum aclmod /pool/homelab-svc -token 'automation@pve!ansible' -role PVEVMAdmin
#   # PVEVMAdmin does NOT include Pool.Audit, so /cluster/resources omits the
#   # `pool` field for this token even though it fully manages the VM through
#   # the pool ACL. roles/pve_vm's immutable-identity check on an EXISTING VM
#   # asserts pve_existing_vm.pool == pve_vm_pool, so without this grant that
#   # assertion always fails ('' != 'homelab-svc') the first time the role
#   # runs against an already-provisioned VM. PVEPoolUser is stock and is
#   # exactly Pool.Audit (no allocate/write capability) — grant it too:
#   pveum aclmod /pool/homelab-svc -user automation@pve -role PVEPoolUser
#   pveum aclmod /pool/homelab-svc -token 'automation@pve!ansible' -role PVEPoolUser
#   # Disk allocation on the VM storage + snippet/image storage:
#   pveum aclmod /storage/nvme0pool -user automation@pve -role PVEDatastoreUser
#   pveum aclmod /storage/nvme0pool -token 'automation@pve!ansible' -role PVEDatastoreUser
#   pveum aclmod /storage/local     -user automation@pve -role PVEDatastoreUser
#   pveum aclmod /storage/local     -token 'automation@pve!ansible' -role PVEDatastoreUser
#   # serial-port config is gated at / with Sys.Modify (PVE quirk); grant it
#   # via a single-privilege custom role, NOT PVEVMAdmin-at-/:
#   pveum role add homelab-sysmodify -privs Sys.Modify
#   pveum aclmod / -user automation@pve -role homelab-sysmodify
#   pveum aclmod / -token 'automation@pve!ansible' -role homelab-sysmodify
#   # PVE 8: NIC attachment needs SDN.Use on the bridge:
#   pveum role add homelab-sdnuse -privs SDN.Use
#   pveum aclmod /sdn/zones/localnetwork/vmbr0 -user automation@pve -role homelab-sdnuse
#   pveum aclmod /sdn/zones/localnetwork/vmbr0 -token 'automation@pve!ansible' -role homelab-sdnuse
#
# Honest scope note: the qm import / EFI-disk steps run as root over SSH
# anyway (module limitation), so this scoping protects against TOKEN leakage,
# not against compromise of the control node's SSH key. If the first create
# 403s on some edge permission, widen deliberately (add Sys.Audit on /nodes/
# thurgadin via a custom role) rather than reverting to PVEVMAdmin-at-/.
vault_pve_token_id:     "automation@pve!ansible"
vault_pve_token_secret: "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# --- Mullvad WireGuard (from your generated config; wg(8) fields only) ---
vault_mullvad_privkey:    "REPLACE_base64_private_key"
vault_mullvad_peer_pubkey: "REPLACE_mullvad_server_public_key"
vault_mullvad_endpoint_ip: "185.x.x.x"      # NUMERIC endpoint IP
# Any port your generated config uses is fine now — v5 derives BOTH the
# nftables endpoint-IP set and the endpoint-PORT set from peer.conf, so the
# backstop no longer assumes 51820.
vault_mullvad_endpoint_port: 51820
vault_mullvad_wg_addr:    "10.65.x.x/32"     # your assigned tunnel Address

# (v6: the service VMs no longer run Tailscale — remote access is via a
# dedicated subnet-router VM — so there is no vault_tailscale_authkey here.)

# --- ntfy auth (only if your ntfy requires a token; else leave empty) ---
vault_ntfy_token: ""

# --- RomM (v6): DB creds + optional metadata providers -------------------
# DB_PASSWD in romm.env must equal MARIADB_PASSWORD in romm-db.env — both
# come from vault_romm_db_password. Adopting an already-running DB? set this
# to the CURRENT value, then rotate it inside MariaDB during maintenance.
# Never reset an initialized database directory during normal convergence.
vault_romm_db_password:      "REPLACE_db_password"
vault_romm_db_root_password: "REPLACE_db_root_password"
vault_romm_auth_secret_key:  "REPLACE_openssl_rand_hex_32"   # openssl rand -hex 32
# Metadata providers — all optional; leave "" to skip. Enrich ROMs you ingest.
vault_romm_igdb_client_id:      ""   # https://api-docs.igdb.com (Twitch app)
vault_romm_igdb_client_secret:  ""
vault_screenscraper_user:       ""
vault_screenscraper_password:   ""
vault_steamgriddb_api_key:      ""
vault_mobygames_api_key:        ""
vault_retroachievements_api_key: ""

# Beszel monitoring (v6): the universal token and hub public key can only be
# generated by visiting the hub's own web UI once after it first deploys
# (Settings > Tokens for the universal token; the key is shown when adding a
# system) — there is no API/CLI path to generate them ahead of time.
# Deploying with these empty is fine: the hub comes up normally, agents on
# all three VMs skip themselves with a WARNING (matching the ntfy_url
# first-run pattern) until these are filled in and the deploy re-run. See
# docs/services.md "Beszel monitoring setup".
vault_beszel_token: ""
vault_beszel_key:   ""

# Paperless-ngx (v6): autogenerated Django secret key.
vault_paperless_secret_key: "REPLACE_openssl_rand_hex_32"   # openssl rand -hex 32

# NetBox (v6): autogenerated secrets.
vault_netbox_db_password:        "REPLACE_openssl_rand_hex_24"   # openssl rand -hex 24
vault_netbox_secret_key:         "REPLACE_openssl_rand_hex_32"   # openssl rand -hex 32 (NetBox requires 50+ chars; hex32 is 64)
vault_netbox_redis_password:     "REPLACE_openssl_rand_hex_24"   # openssl rand -hex 24
vault_netbox_superuser_password: "REPLACE_openssl_rand_hex_16"   # openssl rand -hex 16

# Immich (v6): autogenerated database password.
vault_immich_db_password: "REPLACE_openssl_rand_hex_24"   # openssl rand -hex 24

# code-server (v6, infra_secret_apps): autogenerated web-UI login password.
vault_codeserver_password: "REPLACE_openssl_rand_hex_24"   # openssl rand -hex 24

# Semaphore UI (v6, infra_secret_apps): admin password + the base64 key that
# encrypts the secrets Semaphore stores. The encryption key must stay stable
# across restarts or stored SSH keys/vault passwords become unreadable.
vault_semaphore_admin_password:        "REPLACE_openssl_rand_hex_24"      # openssl rand -hex 24
vault_semaphore_access_key_encryption: "REPLACE_openssl_rand_base64_32"   # openssl rand -base64 32
